# 服务器配置
APP_HOST=127.0.0.1
APP_PORT=8000

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_PASSWORD=
DB_NAME=interview_echo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=knowledge_base

# LLM（OpenAI / DeepSeek / 通义千问 / 任何兼容 OpenAI 接口的模型）
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo
EMBEDDING_MODEL=text-embedding-v4

# 语音识别（默认使用阿里云百炼千问 ASR；ASR_API_KEY 为空时复用 LLM_API_KEY）
ASR_PROVIDER=dashscope
ASR_API_KEY=
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
ASR_MODEL=qwen3-asr-flash
ASR_LANGUAGE=zh
ASR_TIMEOUT_SECONDS=35
ASR_ENABLE_ITN=true
ASR_TRANSCODE_AUDIO=true
ASR_MAX_AUDIO_BYTES=10485760
VOICE_UPLOAD_DIR=/srv/interviewecho/shared/voice

# 面试官 TTS（MiMo-V2.5-TTS；生产环境请在服务器环境变量中配置 API Key）
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_TTS_AUDIO_FORMAT=wav
MIMO_TTS_TIMEOUT_SECONDS=60

# 面试追问控制
INTERVIEW_MAX_FOLLOW_UPS_PER_QUESTION=1
INTERVIEW_SHORT_ROUNDS_MAX_FOLLOW_UPS=0

# LLM（DeepSeek 兼容配置，可按需映射到上面的 LLM_*）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 语音识别（Whisper）
WHISPER_MODEL=base
WHISPER_CACHE_DIR=/srv/interviewecho/shared/whisper-cache
WHISPER_LANGUAGE=zh
WHISPER_WORD_TIMESTAMPS=false
WHISPER_PRELOAD=true

# 代码练习（自建 Judge0，仅供后端访问，不使用云 API）
JUDGE0_BASE_URL=http://127.0.0.1:2358
JUDGE0_TIMEOUT_SECONDS=12
JUDGE0_POLL_INTERVAL_SECONDS=0.6
JUDGE0_MAX_POLL_ATTEMPTS=90
CODE_MAX_SOURCE_LENGTH=20000
CODE_MAX_TEST_CASES=30
CODE_MAX_CONCURRENT_JUDGE_CASES=8
CODE_OUTPUT_LIMIT=4000
